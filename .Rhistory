library(tidyverse)
iris_long <- iris %>% group_by(Species) %>%
summarise(mean_PL = mean(Petal.Length)) %>%
ungroup()
iris_long <- iris %>%
mutate(Ind = 1:150) %>%
pivot_longer(cols = 1:4, names_to = "Variable",
values_to = "Value")
View(iris_long)
iris_wide <- iris_long %>%
pivot_wider(names_from = Variable, values_from = Value)
View(iris_wide)
